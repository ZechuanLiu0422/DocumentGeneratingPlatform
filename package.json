{
  "name": "docu-generating-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-next-dev.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:phase-04:ops:limiter": "node --experimental-strip-types --test tests/phase-04/ops/distributed-ratelimit.test.ts",
    "test:phase-04:contracts": "node --experimental-strip-types --experimental-test-module-mocks --test-concurrency=1 --test tests/phase-04/contracts/*.test.ts",
    "test:phase-04:contracts:harness": "node --experimental-strip-types --experimental-test-module-mocks --test-concurrency=1 --test tests/phase-04/contracts/harness-smoke.test.ts",
    "test:phase-04:contracts:foundation": "node --experimental-strip-types --experimental-test-module-mocks --test-concurrency=1 --test tests/phase-04/contracts/operation-foundation-contract.test.ts",
    "test:phase-03:contracts": "node --experimental-strip-types --experimental-test-module-mocks --test-concurrency=1 --test tests/phase-03/contracts/*.test.ts",
    "test:phase-03:contracts:harness": "node --experimental-strip-types --experimental-test-module-mocks --test-concurrency=1 --test tests/phase-03/contracts/shared-fixtures.ts",
    "test:phase-03:contracts:foundation": "node --experimental-strip-types --experimental-test-module-mocks --test-concurrency=1 --test tests/phase-03/contracts/provenance-persistence-contract.test.ts tests/phase-03/contracts/change-candidate-contract.test.ts",
    "test:phase-02:contracts": "node --experimental-strip-types --experimental-test-module-mocks --test-concurrency=1 --test tests/phase-02/contracts/*.test.ts",
    "test:phase-02:contracts:harness": "node --experimental-strip-types --experimental-test-module-mocks --test-concurrency=1 --test tests/phase-02/contracts/harness-smoke.test.ts",
    "test:phase-02:contracts:ci": "npm run test:phase-02:contracts",
    "test:phase-02:rls:start": "npx supabase start",
    "test:phase-02:rls:reset": "npm run test:phase-02:rls:start && npx supabase db reset --local --no-seed",
    "test:phase-02:rls:seed": "node scripts/seed-phase-2.mjs",
    "test:phase-02:e2e:seed": "node scripts/seed-phase-2.mjs --e2e",
    "test:phase-02:e2e:install": "playwright install chromium",
    "test:phase-02:e2e": "playwright test --config=playwright.config.ts --project=chromium tests/e2e/generate-smoke.spec.ts",
    "test:phase-03:e2e": "npm run test:phase-02:e2e:seed && playwright test --config=playwright.config.ts --project=chromium tests/e2e/generate-smoke.spec.ts",
    "test:phase-02:rls": "node --experimental-strip-types --test-concurrency=1 --test tests/phase-02/auth-rls/auth-rls.test.ts",
    "test:phase-02:telemetry": "node --experimental-strip-types --test tests/phase-02/telemetry/telemetry-contract.test.ts tests/phase-02/telemetry/workflow-route-telemetry.test.ts tests/phase-02/telemetry/health-contract.test.ts",
    "check:deploy": "node --env-file=.env scripts/check-deploy.mjs",
    "check:schema": "node --env-file=.env.local scripts/check-supabase-schema.mjs",
    "invite:user": "node --env-file=.env scripts/invite-user.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "docx": "^9.6.1",
    "mammoth": "^1.12.0",
    "next": "14.2.0",
    "openai": "^6.32.0",
    "pdfjs-dist": "^5.5.207",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8",
    "supabase": "^2.84.4",
    "tailwindcss": "^3.4.0",
    "typescript": "^5"
  }
}
