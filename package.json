{
  "name": "docu-generating-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-next-dev.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:phase-02:contracts": "node --experimental-strip-types --experimental-test-module-mocks --test-concurrency=1 --test tests/phase-02/contracts/*.test.ts",
    "test:phase-02:contracts:harness": "node --experimental-strip-types --experimental-test-module-mocks --test-concurrency=1 --test tests/phase-02/contracts/harness-smoke.test.ts",
    "test:phase-02:contracts:ci": "npm run test:phase-02:contracts",
    "test:phase-02:rls:start": "npx supabase start",
    "test:phase-02:rls:reset": "npm run test:phase-02:rls:start && npx supabase db reset --local --no-seed",
    "test:phase-02:rls:seed": "node scripts/seed-phase-2.mjs",
    "test:phase-02:rls": "node --experimental-strip-types --test-concurrency=1 --test tests/phase-02/auth-rls/auth-rls.test.ts",
    "check:deploy": "node --env-file=.env scripts/check-deploy.mjs",
    "check:schema": "node --env-file=.env.local scripts/check-supabase-schema.mjs",
    "invite:user": "node --env-file=.env scripts/invite-user.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "docx": "^9.6.1",
    "mammoth": "^1.12.0",
    "next": "14.2.0",
    "openai": "^6.32.0",
    "pdfjs-dist": "^5.5.207",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8",
    "supabase": "^2.84.4",
    "tailwindcss": "^3.4.0",
    "typescript": "^5"
  }
}
